{
  "title": "metric-stream",
  "uid": "metric-stream-v1",
  "description": "실시간 API 로그 모니터링",
  "tags": ["metric-stream"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 38,
  "version": 2,
  "panels": [
    {
      "id": 1,
      "title": "총 요청 수",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, COUNT(*) AS \"Requests\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "에러 건수",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, COUNT(*) AS \"Errors\" FROM api_logs WHERE status_code >= 400 AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "에러율",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE status_code >= 400) / NULLIF(COUNT(*), 0), 1) AS \"Error Rate\" FROM api_logs WHERE $__timeFilter(timestamp)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "평균 응답시간",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT ROUND(AVG(response_time_ms)::numeric, 0) AS \"Avg ms\" FROM api_logs WHERE $__timeFilter(timestamp)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "시간대별 요청 수",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 5 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, COUNT(*) AS \"전체 요청\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, COUNT(*) AS \"에러\" FROM api_logs WHERE status_code >= 400 AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "gradientMode": "opacity" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "에러" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 10 }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "에러율 추이",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, ROUND(100.0 * COUNT(*) FILTER (WHERE status_code >= 400) / NULLIF(COUNT(*), 0), 1) AS \"Error Rate %\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "gradientMode": "opacity",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "상태코드 분포",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT status_code::text AS \"Code\", COUNT(*) AS \"Count\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY status_code ORDER BY status_code",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              { "fieldName": "Code", "handlerKey": "field.name" },
              { "fieldName": "Count", "handlerKey": "field.value" }
            ]
          }
        }
      ],
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "200" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "201" }, "properties": [{ "id": "color", "value": { "fixedColor": "teal", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "400" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "401" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "404" }, "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "500" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "디바이스 타입",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 7, "x": 8, "y": 14 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT device_type AS \"Type\", COUNT(*) AS \"Count\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY device_type ORDER BY \"Count\" DESC",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              { "fieldName": "Type", "handlerKey": "field.name" },
              { "fieldName": "Count", "handlerKey": "field.value" }
            ]
          }
        }
      ],
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "엔드포인트별 요청 TOP 10",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 9, "x": 15, "y": 14 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT endpoint AS \"Endpoint\", COUNT(*) AS \"Requests\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY endpoint ORDER BY \"Requests\" DESC LIMIT 10",
          "format": "table"
        }
      ],
      "options": {
        "xField": "Endpoint",
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "리전별 트래픽",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT region AS \"Region\", COUNT(*) AS \"Requests\" FROM api_logs WHERE $__timeFilter(timestamp) GROUP BY region ORDER BY \"Requests\" DESC",
          "format": "table"
        }
      ],
      "options": {
        "xField": "Region",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "리전별 평균 응답시간",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 23 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, AVG(response_time_ms) AS \"Seoul\" FROM api_logs WHERE region = 'seoul' AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, AVG(response_time_ms) AS \"Busan\" FROM api_logs WHERE region = 'busan' AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, AVG(response_time_ms) AS \"Daejeon\" FROM api_logs WHERE region = 'daejeon' AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "D",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, AVG(response_time_ms) AS \"Incheon\" FROM api_logs WHERE region = 'incheon' AND $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "gradientMode": "opacity" }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "최근 500 에러",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "postgres", "uid": "metric-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metric-postgres" },
          "rawSql": "SELECT timestamp, server_id AS \"Server\", region AS \"Region\", method AS \"Method\", endpoint AS \"Endpoint\", response_time_ms AS \"Response Time (ms)\", error_message AS \"Error\" FROM api_logs WHERE status_code = 500 AND $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 20",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Response Time (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 500 },
                  { "color": "red", "value": 1500 }
                ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Server" },
            "properties": [{ "id": "custom.width", "value": 110 }]
          },
          {
            "matcher": { "id": "byName", "options": "Region" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "Method" },
            "properties": [{ "id": "custom.width", "value": 70 }]
          }
        ]
      }
    }
  ]
}
